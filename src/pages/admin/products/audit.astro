---
export const prerender = false;

import AdminLayout from '../layout.astro';
import { env } from 'cloudflare:workers';
import { getSettings } from '../../../lib/pricing';

const user = Astro.locals.user;

let products: any[] = [];
let jpy_to_idr_rate = 110;
let global_fee_pct = 5;
let product_categories: string[] = [];

try {
  const { DB } = (env as any);
  if (DB) {
    const settings = await getSettings(DB);
    jpy_to_idr_rate = settings.jpy_to_idr_rate;
    global_fee_pct = settings.global_fee_pct;
    product_categories = settings.product_categories;

    const productsResult = await DB.prepare(`
      SELECT p.*,
        COALESCE(SUM(CASE WHEN v.is_deleted = 0 THEN 1 ELSE 0 END), 0) AS variant_count,
        COALESCE(SUM(CASE WHEN v.is_deleted = 0 AND (v.product_url IS NULL OR v.product_url = '') THEN 1 ELSE 0 END), 0) AS missing_links_count,
        COALESCE(SUM(CASE WHEN v.is_deleted = 0 AND (v.images IS NULL OR v.images = '' OR v.images = '[]') THEN 1 ELSE 0 END), 0) AS missing_images_count
      FROM products p
      LEFT JOIN product_variants v ON v.product_id = p.id
      WHERE p.is_deleted = 0
      GROUP BY p.id
      ORDER BY p.created_at DESC
    `).all();

    const variantsResult = await DB.prepare(`
      SELECT * FROM product_variants
      WHERE is_deleted = 0
      ORDER BY sort_order ASC
    `).all();

    const productsRaw = productsResult?.results || [];
    const variantsRaw = variantsResult?.results || [];

    const productsMap = new Map();
    for (const p of productsRaw) {
      productsMap.set(p.id, {
        ...p,
        images: (() => { try { return JSON.parse(p.images || '[]'); } catch { return []; } })(),
        notes: (() => { try { return JSON.parse(p.notes || '[]'); } catch { return []; } })(),
        variants: []
      });
    }

    for (const v of variantsRaw) {
      const product = productsMap.get(v.product_id);
      if (product) {
        product.variants.push({
          ...v,
          images: (() => { try { return JSON.parse(v.images || '[]'); } catch { return []; } })()
        });
      }
    }

    products = Array.from(productsMap.values());
  }
} catch (err) {
  console.error('Audit products query error:', err);
}
---

<AdminLayout title="Audit Katalog" user={user} currentPath="/admin/products/audit">
  <div
    id="audit-root"
    data-products={JSON.stringify(products)}
    data-jpy-rate={jpy_to_idr_rate}
    data-fee-pct={global_fee_pct}
    data-categories={JSON.stringify(product_categories)}
  >
    <div class="mb-6 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
      <div>
        <h2 class="text-[1.5rem] font-bold text-[#1A1D23] tracking-[-0.02em]">Audit Katalog</h2>
        <p class="text-[0.8125rem] text-[#5B606D]">Audit dan kelola data link/foto untuk varian produk jastip.</p>
      </div>
    </div>

    <!-- Filter Container -->
    <div class="bg-[#FFFFFF] border border-[#E8E9ED] rounded-[10px] p-4 mb-6 shadow-sm flex flex-col md:flex-row gap-4">
      <div class="flex-1 flex flex-col gap-1">
        <label for="search-input" class="text-[0.8125rem] font-semibold text-[#1A1D23]">Cari Produk</label>
        <input
          type="text"
          id="search-input"
          placeholder="Cari nama atau deskripsi produk..."
          class="w-full h-[40px] px-3 border border-[#E8E9ED] rounded-[6px] text-[0.875rem] focus:outline-none focus:ring-2 focus:ring-[#1A8F89] bg-white text-[#1A1D23]"
        />
      </div>
      <div class="w-full md:w-[200px] flex flex-col gap-1">
        <label for="category-filter" class="text-[0.8125rem] font-semibold text-[#1A1D23]">Kategori</label>
        <select
          id="category-filter"
          class="w-full h-[40px] px-3 border border-[#E8E9ED] rounded-[6px] text-[0.875rem] focus:outline-none focus:ring-2 focus:ring-[#1A8F89] bg-white text-[#1A1D23]"
        >
          <option value="all">Semua Kategori</option>
          {product_categories.map((cat) => (
            <option value={cat}>{cat}</option>
          ))}
        </select>
      </div>
      <div class="w-full md:w-[200px] flex flex-col gap-1">
        <label for="issue-filter" class="text-[0.8125rem] font-semibold text-[#1A1D23]">Filter Masalah</label>
        <select
          id="issue-filter"
          class="w-full h-[40px] px-3 border border-[#E8E9ED] rounded-[6px] text-[0.875rem] focus:outline-none focus:ring-2 focus:ring-[#1A8F89] bg-white text-[#1A1D23]"
        >
          <option value="all">Semua Produk</option>
          <option value="has_issue">Bermasalah (Tanpa Link / Foto)</option>
          <option value="missing_link">Tanpa Link</option>
          <option value="missing_image">Tanpa Foto</option>
        </select>
      </div>
    </div>

    <!-- Table Container -->
    <div class="bg-[#FFFFFF] border border-[#E8E9ED] rounded-[10px] overflow-hidden shadow-sm mb-6">
      <div class="overflow-x-auto w-full">
        <table id="products-table" class="w-full text-[0.875rem] border-collapse">
          <thead>
            <tr class="bg-[#F9F9F7] border-b border-[#E8E9ED] text-left text-[0.6875rem] font-semibold uppercase tracking-[0.1em] text-[#5B606D]">
              <th class="py-3 px-4 w-[80px] text-center">Toggle</th>
              <th class="py-3 px-4 w-[80px]">Thumbnail</th>
              <th class="py-3 px-4">Name</th>
              <th class="py-3 px-4">Category</th>
              <th class="py-3 px-4 text-center">Variants</th>
              <th class="py-3 px-4">Audit Status</th>
            </tr>
          </thead>
          <tbody id="products-tbody">
            <!-- Rendered dynamically via JS -->
          </tbody>
        </table>
      </div>
    </div>
  </div>
</AdminLayout>

<script>
  function init() {
    const root = document.getElementById('audit-root');
    if (!root) return;

    const products = JSON.parse(root.dataset.products || '[]');
    const rate = parseFloat(root.dataset.jpyRate || '0');
    const fee = parseFloat(root.dataset.feePct || '0');
    const categories = JSON.parse(root.dataset.categories || '[]');

    const searchInput = document.getElementById('search-input') as HTMLInputElement | null;
    const categoryFilter = document.getElementById('category-filter') as HTMLSelectElement | null;
    const issueFilter = document.getElementById('issue-filter') as HTMLSelectElement | null;
    const tbody = document.getElementById('products-tbody');

    if (!searchInput || !categoryFilter || !issueFilter || !tbody) return;

    function renderTable() {
      if (!searchInput || !categoryFilter || !issueFilter || !tbody) return;

      const searchVal = searchInput.value.toLowerCase().trim();
      const catVal = categoryFilter.value;
      const issueVal = issueFilter.value;

      const filtered = products.filter((p: any) => {
        const matchesSearch = !searchVal ||
          p.name.toLowerCase().includes(searchVal) ||
          (p.description && p.description.toLowerCase().includes(searchVal));

        const matchesCategory = catVal === 'all' || p.category === catVal;

        let matchesIssue = true;
        if (issueVal === 'missing_link') {
          matchesIssue = Number(p.missing_links_count) > 0;
        } else if (issueVal === 'missing_image') {
          matchesIssue = Number(p.missing_images_count) > 0;
        } else if (issueVal === 'has_issue') {
          matchesIssue = Number(p.missing_links_count) > 0 || Number(p.missing_images_count) > 0;
        }

        return matchesSearch && matchesCategory && matchesIssue;
      });

      if (filtered.length === 0) {
        tbody.innerHTML = `
          <tr>
            <td colspan="6" class="py-12 text-center text-[#5B606D]">
              Tidak ada produk yang ditemukan.
            </td>
          </tr>
        `;
        return;
      }

      tbody.innerHTML = filtered.map((p: any) => {
        const firstVariantImg = p.variants?.[0]?.images?.[0];
        const fallbackUrl = 'https://images.unsplash.com/photo-1595225476474-87563907a212?auto=format&fit=crop&q=80&w=800';
        const imgSrc = firstVariantImg || p.images?.[0] || fallbackUrl;

        let badgesHtml = '';
        const missingLink = Number(p.missing_links_count) > 0;
        const missingImage = Number(p.missing_images_count) > 0;

        if (missingLink) {
          badgesHtml += `<span class="bg-[#FDF2F2] text-[#D1453B] border border-[#FDE2E2] px-[8px] py-[2px] rounded-[3px] text-[0.625rem] font-semibold uppercase tracking-[0.1em] mr-1.5">Tanpa Link</span>`;
        }
        if (missingImage) {
          badgesHtml += `<span class="bg-[#FFF8F2] text-[#D97706] border border-[#FFEBE0] px-[8px] py-[2px] rounded-[3px] text-[0.625rem] font-semibold uppercase tracking-[0.1em] mr-1.5">Tanpa Foto</span>`;
        }
        if (!missingLink && !missingImage) {
          badgesHtml += `<span class="bg-[#DEF7EC] text-[#03543F] border border-[#BCF0DA] px-[8px] py-[2px] rounded-[3px] text-[0.625rem] font-semibold uppercase tracking-[0.1em]">Lengkap</span>`;
        }

        return `
          <tr class="border-b border-[#E8E9ED] hover:bg-[#F9F9F7]/50 transition-colors product-row" data-id="${p.id}">
            <td class="py-3 px-4 text-center">
              <button class="toggle-btn p-1 hover:bg-[#E8E9ED] rounded-[4px] transition-colors focus:outline-none" data-product-id="${p.id}">
                <svg class="w-4 h-4 text-[#5B606D] transform transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
              </button>
            </td>
            <td class="py-3 px-4">
              <img src="${imgSrc}" alt="${p.name}" class="w-12 h-12 object-cover rounded-[4px] border border-[#E8E9ED]" />
            </td>
            <td class="py-3 px-4 font-bold text-[#1A1D23] max-w-[280px] truncate">${p.name}</td>
            <td class="py-3 px-4">
              <span class="bg-[#E8E9ED] text-[#1A1D23] px-[8px] py-[2px] rounded-[3px] text-[0.625rem] font-semibold uppercase tracking-[0.1em]">
                ${p.category}
              </span>
            </td>
            <td class="py-3 px-4 text-center">
              <span class="bg-[#D5EDEB] text-[#0F726E] px-2 py-0.5 rounded-full text-[0.6875rem] font-semibold">
                ${p.variant_count} varian
              </span>
            </td>
            <td class="py-3 px-4">${badgesHtml}</td>
          </tr>
          <tr class="hidden variant-subrow bg-[#FAF8F5]/30 border-b border-[#E8E9ED]" id="variants-row-${p.id}">
            <td colspan="6" class="p-4">
              <div id="variants-container-${p.id}"></div>
            </td>
          </tr>
        `;
      }).join('');
    }

    tbody.addEventListener('click', (e) => {
      const toggleBtn = (e.target as HTMLElement).closest('.toggle-btn');
      if (!toggleBtn) return;
      const productId = toggleBtn.getAttribute('data-product-id');
      if (!productId) return;
      const subrow = document.getElementById(`variants-row-${productId}`);
      if (!subrow) return;

      const isHidden = subrow.classList.contains('hidden');
      if (isHidden) {
        subrow.classList.remove('hidden');
        const svg = toggleBtn.querySelector('svg');
        if (svg) svg.classList.add('rotate-90');
        renderVariantsForProduct(productId);
      } else {
        subrow.classList.add('hidden');
        const svg = toggleBtn.querySelector('svg');
        if (svg) svg.classList.remove('rotate-90');
      }
    });

    function esc(s: any) {
      return String(s ?? '').replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    }

    function renderQuickAddFormHtml(productId: string) {
      return `
        <div class="flex flex-wrap items-center gap-3 bg-[#F9F9F7] border border-[#E8E9ED] rounded-[8px] p-3 quick-add-form" data-product-id="${productId}">
          <div class="flex-1 min-w-[200px]">
            <input type="text" class="quick-variant-name w-full h-8 px-2 border border-[#E8E9ED] rounded-[6px] text-[0.8125rem] focus:outline-none focus:ring-2 focus:ring-[#1A8F89] bg-white text-[#1A1D23]"
                   placeholder="Nama Varian *" data-product-id="${productId}" required />
          </div>
          <div class="flex-1 min-w-[250px]">
            <input type="text" class="quick-variant-url w-full h-8 px-2 border border-[#E8E9ED] rounded-[6px] text-[0.8125rem] focus:outline-none focus:ring-2 focus:ring-[#1A8F89] bg-white text-[#1A1D23]"
                   placeholder="URL Link (opsional)" data-product-id="${productId}" />
          </div>
          <div class="flex items-center gap-1.5 shrink-0">
            <input type="number" class="quick-variant-price w-20 h-8 px-2 border border-[#E8E9ED] rounded-[6px] text-[0.8125rem] focus:outline-none focus:ring-2 focus:ring-[#1A8F89] bg-white text-[#1A1D23]"
                   placeholder="JPY *" min="0" data-product-id="${productId}" required />
            <span class="text-xs text-[#5B606D]">¥</span>
            <div class="quick-price-idr font-mono text-[0.8125rem] text-[#0F726E] font-semibold w-24 text-right" id="quick-idr-${productId}">
              Rp 0
            </div>
          </div>
          <button type="button" class="btn-add-variant-submit h-8 px-4 bg-[#1A8F89] hover:bg-[#157A75] text-white rounded-[6px] text-xs font-semibold transition-colors shrink-0" data-product-id="${productId}">
            Tambah Varian
          </button>
        </div>
      `;
    }

    function attachVariantActionListeners(productId: string) {
      // Stub function to be implemented later
    }

    function attachQuickAddListeners(productId: string) {
      // Stub function to be implemented later
    }

    function renderVariantsForProduct(productId: string) {
      const product = products.find((p: any) => p.id === productId);
      if (!product) return;

      const container = document.getElementById(`variants-container-${productId}`);
      if (!container) return;

      const activeVariants = product.variants || [];

      const calcIdr = (jpyVal: any) => {
        const jpy = parseFloat(jpyVal) || 0;
        return Math.ceil(jpy * rate * (1 + fee / 100) / 1000) * 1000;
      };
      const formatIdr = (val: number) => {
        return 'Rp ' + val.toLocaleString('id-ID');
      };

      let html = '';

      if (activeVariants.length === 0) {
        html += `
          <div class="text-[#5B606D] text-[0.875rem] py-4 px-4 bg-[#FAF8F5] border border-dashed border-[#E8E9ED] rounded-[8px] mb-4 text-center">
            Belum ada varian. Gunakan form di bawah untuk menambah.
          </div>
        `;
      } else {
        html += `<div class="flex flex-col gap-3 mb-6">`;
        for (const v of activeVariants) {
          const vImgSrc = v.images?.[0] || '';
          html += `
            <div class="flex flex-wrap items-center gap-3 bg-white p-3 border border-[#E8E9ED] rounded-[8px] variant-row-item" data-variant-id="${v.id}">
              <div class="flex items-center gap-2 shrink-0">
                <div class="w-10 h-10 rounded border border-[#E8E9ED] bg-[#F1F2F5] bg-cover bg-center shrink-0 variant-img-preview"
                     style="${vImgSrc ? `background-image: url('${vImgSrc}');` : ''}"
                     id="variant-preview-${v.id}">
                </div>
                <button type="button" class="btn-variant-upload h-8 px-2 border border-[#E8E9ED] hover:bg-[#F1F2F5] text-[#1A1D23] rounded-[6px] text-xs font-semibold shrink-0" data-variant-id="${v.id}">
                  Upload Foto
                </button>
                <input type="file" class="variant-file-input hidden" accept="image/*" data-variant-id="${v.id}" />
                <input type="text" class="variant-image-url h-8 px-2 border border-[#E8E9ED] rounded-[6px] text-[0.8125rem] focus:outline-none focus:ring-2 focus:ring-[#1A8F89] bg-white text-[#1A1D23] w-28 text-ellipsis"
                       placeholder="URL Foto" value="${esc(vImgSrc)}" data-variant-id="${v.id}" />
              </div>

              <input type="text" class="variant-name flex-1 min-w-[150px] h-8 px-2 border border-[#E8E9ED] rounded-[6px] text-[0.8125rem] focus:outline-none focus:ring-2 focus:ring-[#1A8F89] bg-white text-[#1A1D23]"
                     value="${esc(v.variant_name)}" placeholder="Nama Varian" data-variant-id="${v.id}" />

              <div class="flex items-center gap-1 flex-1 min-w-[180px]">
                <input type="text" class="variant-url w-full h-8 px-2 border border-[#E8E9ED] rounded-[6px] text-[0.8125rem] focus:outline-none focus:ring-2 focus:ring-[#1A8F89] bg-white text-[#1A1D23]"
                       value="${esc(v.product_url)}" placeholder="URL Link" data-variant-id="${v.id}" />
                <a href="${v.product_url || '#'}" target="_blank"
                   class="variant-link-btn p-1.5 border border-[#E8E9ED] hover:bg-[#F1F2F5] rounded-[6px] shrink-0 text-[#5B606D] ${v.product_url ? '' : 'pointer-events-none opacity-50'}"
                   id="variant-link-btn-${v.id}" title="Buka Link">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                </a>
              </div>

              <div class="flex items-center gap-1.5 shrink-0">
                <input type="number" class="variant-price-jpy w-20 h-8 px-2 border border-[#E8E9ED] rounded-[6px] text-[0.8125rem] focus:outline-none focus:ring-2 focus:ring-[#1A8F89] bg-white text-[#1A1D23]"
                       value="${v.price_jpy}" placeholder="JPY" min="0" data-variant-id="${v.id}" />
                <span class="text-xs text-[#5B606D]">¥</span>
                <div class="variant-price-idr font-mono text-[0.8125rem] text-[#0F726E] font-semibold w-24 text-right" id="variant-idr-${v.id}">
                  ${formatIdr(calcIdr(v.price_jpy))}
                </div>
              </div>

              <div class="flex items-center gap-2 shrink-0">
                <button type="button" class="btn-save-variant h-8 px-3 bg-[#0F726E] hover:bg-[#0A5D59] text-white rounded-[6px] text-xs font-semibold transition-colors" data-variant-id="${v.id}">
                  Simpan
                </button>
                <button type="button" class="btn-delete-variant h-8 px-3 border border-[#E8E9ED] hover:bg-[#FDF3E7] text-[#D1453B] rounded-[6px] text-xs font-semibold transition-colors" data-variant-id="${v.id}">
                  Hapus
                </button>
              </div>
            </div>
          `;
        }
        html += `</div>`;
      }

      html += `
        <div class="mt-4 border-t border-[#E8E9ED] pt-4">
          <h4 class="text-[0.875rem] font-bold text-[#1A1D23] mb-3">Tambah Varian Baru</h4>
          ${renderQuickAddFormHtml(productId)}
        </div>
      `;

      container.innerHTML = html;

      attachVariantActionListeners(productId);
      attachQuickAddListeners(productId);
    }

    searchInput.addEventListener('input', renderTable);
    categoryFilter.addEventListener('change', renderTable);
    issueFilter.addEventListener('change', renderTable);

    // Initial render
    renderTable();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
