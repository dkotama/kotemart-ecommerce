---
export const prerender = false;

import AdminLayout from './layout.astro';
import { env } from 'cloudflare:workers';
import type { Settings } from '../../lib/types';
import { getSettings } from '../../lib/pricing';

const user = Astro.locals.user;

let settings: Settings = {
  gate_status: 'Closed',
  jpy_to_idr_rate: 110,
  global_fee_pct: 5,
  telegram_link: '',
  product_categories: ['Elektronik', 'Figure', 'Snack', 'Pakaian'],
  note_templates: [],
};
let tokens: { id: string; label: string; created_at: string; last_used_at: string | null; revoked_at: string | null }[] = [];

try {
  const db = (env as any).DB;
  if (db) {
    settings = await getSettings(db);
    const res = await db.prepare(`SELECT id, label, created_at, last_used_at, revoked_at FROM api_tokens ORDER BY created_at DESC`).all();
    tokens = res.results || [];
  }
} catch (err) {
  console.error('Admin settings fetch error:', err);
}

const isGateOpen = settings.gate_status === 'Open';
---

<AdminLayout title="Pengaturan" user={user} currentPath="/admin/settings">
  <div class="mb-6">
    <h2 class="text-[1.5rem] font-bold text-[#1A1D23] tracking-[-0.02em]">Pengaturan Sistem</h2>
    <p class="text-[0.8125rem] text-[#5B606D]">Atur kurs mata uang, fee persentase, status pembukaan jastip, dan link kontak Telegram.</p>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 items-start">
    
    <!-- Left Column: Gate and Settings Forms -->
    <div class="flex flex-col gap-6">
      
      <!-- Gate Control Card -->
      <div class="bg-[#FFFFFF] border border-[#E8E9ED] rounded-[10px] p-[24px] shadow-sm">
        <h3 class="font-bold text-[1.125rem] text-[#1A1D23] mb-2 leading-tight">Status Pembukaan Jastip (Gate Control)</h3>
        <p class="text-[0.8125rem] text-[#5B606D] mb-4">Jika ditutup, pembeli tidak dapat melakukan pemesanan baru (katalog & custom).</p>
        
        <div class="flex items-center justify-between p-4 bg-[#F9F9F7] rounded-[6px] border border-[#E8E9ED]">
          <div class="flex flex-col">
            <span class="text-[0.875rem] font-semibold text-[#1A1D23]" id="gate-status-text">
              Status Jastip: {settings.gate_status}
            </span>
            <span class="text-[0.75rem] text-[#5B606D]">Klik tombol di samping untuk mengubah status jastip.</span>
          </div>
          
          <button
            id="gate-toggle-btn"
            data-testid="gate-toggle"
            data-state={settings.gate_status}
            class={`px-4 h-[36px] rounded-[6px] text-[0.6875rem] font-bold uppercase tracking-[0.1em] transition-all flex items-center justify-center border ${
              isGateOpen
                ? 'bg-[#D9EDE2] border-[#2E8B57] text-[#1E6B3F] hover:bg-[#c9e4d4]'
                : 'bg-[#FDEDEC] border-[#D1453B] text-[#A6312A] hover:bg-[#fadad8]'
            }`}
          >
            {isGateOpen ? 'Buka (Open)' : 'Tutup (Closed)'}
          </button>
        </div>
      </div>

      <!-- Pricing Rules Card -->
      <div class="bg-[#FFFFFF] border border-[#E8E9ED] rounded-[10px] p-[24px] shadow-sm flex flex-col gap-4">
        <h3 class="font-bold text-[1.125rem] text-[#1A1D23] leading-tight">Kurs Yen & Fee Jastip</h3>
        <p class="text-[0.8125rem] text-[#5B606D] -mt-2">Formula IDR = JPY * Kurs * (1 + Fee%). Update tidak merubah histori order yang sudah dipesan.</p>

        <!-- JPY Rate Input -->
        <div class="flex flex-col gap-1 border-t border-[#E8E9ED] pt-4">
          <label for="jpy-rate-input" class="text-[0.8125rem] font-semibold text-[#1A1D23]">Kurs JPY ke IDR (Yen ke Rupiah)</label>
          <div class="flex gap-2">
            <div class="relative flex-grow">
              <span class="absolute left-3 top-1/2 -translate-y-1/2 font-mono text-[0.875rem] text-[#5B606D]">¥ 1 = Rp</span>
              <input
                type="number"
                id="jpy-rate-input"
                data-testid="jpy-rate-input"
                step="0.1"
                min="0.1"
                value={settings.jpy_to_idr_rate}
                class="w-full h-[40px] pl-[68px] pr-3 border border-[#E8E9ED] rounded-[6px] text-[0.875rem] font-mono focus:outline-none focus:ring-2 focus:ring-[#1A8F89]"
              />
            </div>
            <button
              id="btn-save-rate"
              data-testid="btn-save-rate"
              class="btn-primary-custom h-[40px] shrink-0"
            >
              Simpan Kurs
            </button>
          </div>
        </div>

        <!-- Global Fee Input -->
        <div class="flex flex-col gap-1 border-t border-[#E8E9ED] pt-4">
          <label for="fee-input" class="text-[0.8125rem] font-semibold text-[#1A1D23]">Global Jastip Fee (%)</label>
          <div class="flex gap-2">
            <div class="relative flex-grow">
              <input
                type="number"
                id="fee-input"
                step="0.1"
                min="0"
                value={settings.global_fee_pct}
                class="w-full h-[40px] px-3 pr-8 border border-[#E8E9ED] rounded-[6px] text-[0.875rem] font-mono focus:outline-none focus:ring-2 focus:ring-[#1A8F89]"
              />
              <span class="absolute right-3 top-1/2 -translate-y-1/2 font-mono text-[0.875rem] text-[#5B606D]">%</span>
            </div>
            <button
              id="btn-save-fee"
              class="btn-primary-custom h-[40px] shrink-0"
            >
              Simpan Fee
            </button>
          </div>
        </div>

      </div>

    </div>

    <!-- Right Column: Telegram Info & Contacts -->
    <div class="flex flex-col gap-6">
      <div class="bg-[#FFFFFF] border border-[#E8E9ED] rounded-[10px] p-[24px] shadow-sm flex flex-col gap-4">
        <h3 class="font-bold text-[1.125rem] text-[#1A1D23] leading-tight">Link Telegram</h3>
        <p class="text-[0.8125rem] text-[#5B606D] -mt-2">Link tombol chat yang muncul di banner halaman depan jastip ketika gate ditutup.</p>

        <!-- Telegram Link input -->
        <div class="flex flex-col gap-1 border-t border-[#E8E9ED] pt-4">
          <label for="telegram-input" class="text-[0.8125rem] font-semibold text-[#1A1D23]">Link Chat Telegram</label>
          <div class="flex flex-col gap-3">
            <input
              type="url"
              id="telegram-input"
              value={settings.telegram_link}
              placeholder="https://t.me/yourusername"
              class="w-full h-[40px] px-3 border border-[#E8E9ED] rounded-[6px] text-[0.875rem] focus:outline-none focus:ring-2 focus:ring-[#1A8F89]"
            />
            <button
              id="btn-save-telegram"
              class="btn-primary-custom h-[40px] w-full"
            >
              Simpan Link Telegram
            </button>
          </div>
        </div>
      </div>

      <div class="bg-[#FFFFFF] border border-[#E8E9ED] rounded-[10px] p-[24px] shadow-sm flex flex-col gap-4">
        <h3 class="font-bold text-[1.125rem] text-[#1A1D23] leading-tight">Barang Tiba Notification</h3>
        <p class="text-[0.8125rem] text-[#5B606D] -mt-2">Pesan 1 baris yang muncul di halaman beranda & pesanan pembeli. Kosongkan untuk menyembunyikan.</p>

        <div class="flex flex-col gap-1 border-t border-[#E8E9ED] pt-4">
          <div class="flex flex-col gap-3">
            <input
              type="text"
              id="arrival-input"
              value={settings.arrival_notification}
              placeholder="Contoh: Barang tiba 20 Juni 2026, segera lunasi!"
              class="w-full h-[40px] px-3 border border-[#E8E9ED] rounded-[6px] text-[0.875rem] focus:outline-none focus:ring-2 focus:ring-[#1A8F89]"
            />
            <button
              id="btn-save-arrival"
              class="btn-primary-custom h-[40px] w-full"
            >
              Simpan Notification
            </button>
          </div>
        </div>
      </div>

      <div class="bg-[#FFFFFF] border border-[#E8E9ED] rounded-[10px] p-[24px] shadow-sm flex flex-col gap-4">
        <h3 class="font-bold text-[1.125rem] text-[#1A1D23] leading-tight">Informasi Rekening Bank</h3>
        <p class="text-[0.8125rem] text-[#5B606D] -mt-2">Data rekening yang ditampilkan ke pembeli untuk pembayaran.</p>

        <div class="border-t border-[#E8E9ED] pt-4 flex flex-col gap-4">
          <div class="flex flex-col gap-1">
            <label class="text-[0.8125rem] font-semibold text-[#1A1D23]">Nama Bank</label>
            <input type="text" id="bank-name-input" value={settings.bank_name} placeholder="BCA"
              class="w-full h-[40px] px-3 border border-[#E8E9ED] rounded-[6px] text-[0.875rem] focus:outline-none focus:ring-2 focus:ring-[#1A8F89]" />
          </div>
          <div class="flex flex-col gap-1">
            <label class="text-[0.8125rem] font-semibold text-[#1A1D23]">Nomor Rekening</label>
            <input type="text" id="bank-account-input" value={settings.bank_account_number} placeholder="1234567890"
              class="w-full h-[40px] px-3 border border-[#E8E9ED] rounded-[6px] text-[0.875rem] focus:outline-none focus:ring-2 focus:ring-[#1A8F89]" />
          </div>
          <div class="flex flex-col gap-1">
            <label class="text-[0.8125rem] font-semibold text-[#1A1D23]">Atas Nama</label>
            <input type="text" id="bank-nameholder-input" value={settings.bank_account_name} placeholder="Darma Kotama"
              class="w-full h-[40px] px-3 border border-[#E8E9ED] rounded-[6px] text-[0.875rem] focus:outline-none focus:ring-2 focus:ring-[#1A8F89]" />
          </div>
          <button id="btn-save-bank" class="btn-primary-custom h-[40px] w-full">Simpan Rekening</button>
        </div>
      </div>

      <!-- API Tokens Card -->
      <div class="bg-[#FFFFFF] border border-[#E8E9ED] rounded-[10px] p-[24px] shadow-sm flex flex-col gap-4">
        <h3 class="font-bold text-[1.125rem] text-[#1A1D23] leading-tight">API Tokens (AI Assistant)</h3>
        <p class="text-[0.8125rem] text-[#5B606D] -mt-2">Kelola token akses API untuk asisten AI.</p>

        <div class="border-t border-[#E8E9ED] pt-4 flex flex-col gap-4">
          <div class="flex gap-2">
            <input type="text" id="token-label-input" placeholder="Contoh: Claude Admin..." class="flex-grow h-[36px] px-3 border border-[#E8E9ED] rounded-[6px] text-[0.875rem] focus:outline-none focus:ring-2 focus:ring-[#1A8F89]" />
            <button id="btn-generate-token" class="h-[36px] px-4 bg-[#0F726E] text-white hover:bg-[#0A5D59] rounded-[6px] text-[0.6875rem] font-semibold uppercase tracking-[0.1em] transition-all shrink-0">Generate</button>
          </div>

          <!-- Tokens list table -->
          <div class="overflow-x-auto w-full border border-[#E8E9ED] rounded-[6px]">
            <table class="w-full text-[0.8125rem] border-collapse">
              <thead>
                <tr class="bg-[#F9F9F7] border-b border-[#E8E9ED] text-left text-[0.6875rem] font-semibold uppercase tracking-[0.05em] text-[#5B606D]">
                  <th class="py-2 px-3">Label</th>
                  <th class="py-2 px-3">Dibuat</th>
                  <th class="py-2 px-3">Terakhir Digunakan</th>
                  <th class="py-2 px-3 text-right">Aksi</th>
                </tr>
              </thead>
              <tbody>
                {tokens.length === 0 ? (
                  <tr>
                    <td colspan="4" class="py-6 text-center text-[#5B606D] opacity-75">
                      Belum ada token API.
                    </td>
                  </tr>
                ) : (
                  tokens.map(token => (
                    <tr class="border-b border-[#E8E9ED] hover:bg-[#F9F9F7]/50 transition-colors">
                      <td class="py-2.5 px-3 font-semibold text-[#1A1D23]">{token.label}</td>
                      <td class="py-2.5 px-3 text-[#5B606D]">{new Date(token.created_at).toLocaleDateString('id-ID')}</td>
                      <td class="py-2.5 px-3 text-[#5B606D]">{token.last_used_at ? new Date(token.last_used_at).toLocaleDateString('id-ID') : 'Belum pernah'}</td>
                      <td class="py-2.5 px-3 text-right">
                        {token.revoked_at ? (
                          <span class="text-[#D1453B] font-semibold text-[0.75rem] uppercase tracking-[0.05em]">Revoked</span>
                        ) : (
                          <button class="text-[#D1453B] hover:underline font-semibold btn-revoke-token" data-id={token.id}>Revoke</button>
                        )}
                      </td>
                    </tr>
                  ))
                )}
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Token Show Modal -->
      <dialog id="token-show-modal" class="modal">
        <div class="modal-box bg-white max-w-[420px] border border-[#E8E9ED] rounded-[10px] p-6 shadow-lg">
          <h3 class="font-bold text-lg text-[#1A1D23] mb-2">Token API Berhasil Dibuat!</h3>
          <p class="text-[0.8125rem] text-[#5B606D] mb-4">Salin token ini sekarang. Token tidak akan ditampilkan lagi demi keamanan.</p>
          <div class="flex items-center gap-2 bg-[#F9F9F7] p-2.5 rounded border border-[#E8E9ED] mb-4">
            <code id="raw-token-display" class="text-xs break-all flex-grow font-mono font-semibold text-[#0F726E]"></code>
          </div>
          <div class="modal-action">
            <button type="button" class="btn text-xs font-semibold px-4 border rounded-[6px] h-[36px] bg-[#F1F2F5] hover:bg-[#E8E9ED]" onclick="document.getElementById('token-show-modal').close()">Selesai</button>
          </div>
        </div>
      </dialog>
    </div>

    </div>

  </div>
</AdminLayout>

<script>
  const toggleBtn = document.getElementById('gate-toggle-btn') as HTMLButtonElement;
  const gateStatusText = document.getElementById('gate-status-text')!;
  
  const jpyRateInput = document.getElementById('jpy-rate-input') as HTMLInputElement;
  const btnSaveRate = document.getElementById('btn-save-rate') as HTMLButtonElement;
  
  const feeInput = document.getElementById('fee-input') as HTMLInputElement;
  const btnSaveFee = document.getElementById('btn-save-fee') as HTMLButtonElement;

  const telegramInput = document.getElementById('telegram-input') as HTMLInputElement;
  const btnSaveTelegram = document.getElementById('btn-save-telegram') as HTMLButtonElement;

  // Gate Toggle Handler
  toggleBtn?.addEventListener('click', async () => {
    const currentState = toggleBtn.getAttribute('data-state');
    const newState = currentState === 'Open' ? 'Closed' : 'Open';
    
    toggleBtn.disabled = true;

    try {
      const apiClient = (window as any).apiClient || fetch;
      const res = await apiClient('/api/gate/toggle', { method: 'POST' });
      
      if (res.ok) {
        const data = await res.json();
        const finalState = data.status;
        
        toggleBtn.setAttribute('data-state', finalState);
        toggleBtn.textContent = finalState === 'Open' ? 'Buka (Open)' : 'Tutup (Closed)';
        gateStatusText.textContent = `Status Jastip: ${finalState}`;
        
        // Update styling classes
        if (finalState === 'Open') {
          toggleBtn.className = 'px-4 h-[36px] rounded-[6px] text-[0.6875rem] font-bold uppercase tracking-[0.1em] transition-all flex items-center justify-center border bg-[#D9EDE2] border-[#2E8B57] text-[#1E6B3F] hover:bg-[#c9e4d4]';
        } else {
          toggleBtn.className = 'px-4 h-[36px] rounded-[6px] text-[0.6875rem] font-bold uppercase tracking-[0.1em] transition-all flex items-center justify-center border bg-[#FDEDEC] border-[#D1453B] text-[#A6312A] hover:bg-[#fadad8]';
        }

        window.showToast?.(`Status jastip dirubah ke ${finalState}!`, 'success');
      } else {
        const err = await res.json().catch(() => ({}));
        window.showToast?.(err.error || 'Gagal mengubah status jastip.', 'error');
      }
    } catch {
      window.showToast?.('Terjadi kesalahan jaringan.', 'error');
    } finally {
      toggleBtn.disabled = false;
    }
  });

  // Save Settings helper
  async function saveSettings(payload: Record<string, any>, successMsg: string) {
    try {
      const apiClient = (window as any).apiClient || fetch;
      const res = await apiClient('/api/admin/settings', {
        method: 'PUT',
        body: JSON.stringify(payload),
      });

      if (res.ok) {
        window.showToast?.(successMsg, 'success');
      } else {
        const err = await res.json().catch(() => ({}));
        window.showToast?.(err.error || 'Gagal mengupdate pengaturan.', 'error');
      }
    } catch {
      window.showToast?.('Terjadi kesalahan jaringan.', 'error');
    }
  }

  // Save JPY Rate
  btnSaveRate?.addEventListener('click', async () => {
    const rate = parseFloat(jpyRateInput.value);
    if (isNaN(rate) || rate <= 0) {
      window.showToast?.('Nominal kurs tidak valid.', 'error');
      return;
    }
    btnSaveRate.disabled = true;
    await saveSettings({ jpy_to_idr_rate: rate }, 'Kurs Yen berhasil diupdate!');
    btnSaveRate.disabled = false;
  });

  // Save Fee
  btnSaveFee?.addEventListener('click', async () => {
    const fee = parseFloat(feeInput.value);
    if (isNaN(fee) || fee < 0) {
      window.showToast?.('Nominal fee tidak valid.', 'error');
      return;
    }
    btnSaveFee.disabled = true;
    await saveSettings({ global_fee_pct: fee }, 'Fee jastip berhasil diupdate!');
    btnSaveFee.disabled = false;
  });

  // Save Telegram Link
  btnSaveTelegram?.addEventListener('click', async () => {
    const link = telegramInput.value.trim();
    if (link && !link.startsWith('http://') && !link.startsWith('https://')) {
      window.showToast?.('Format URL link Telegram tidak valid.', 'error');
      return;
    }
    btnSaveTelegram.disabled = true;
    await saveSettings({ telegram_link: link }, 'Link Telegram berhasil diupdate!');
    btnSaveTelegram.disabled = false;
  });

  // Save Arrival Notification
  document.getElementById('btn-save-arrival')?.addEventListener('click', async () => {
    const val = (document.getElementById('arrival-input') as HTMLInputElement).value.trim();
    (document.getElementById('btn-save-arrival') as HTMLButtonElement).disabled = true;
    await saveSettings({ arrival_notification: val }, 'Notification berhasil disimpan!');
    (document.getElementById('btn-save-arrival') as HTMLButtonElement).disabled = false;
  });

  // Save Bank Info
  document.getElementById('btn-save-bank')?.addEventListener('click', async () => {
    const bankName = (document.getElementById('bank-name-input') as HTMLInputElement).value.trim();
    const bankAccount = (document.getElementById('bank-account-input') as HTMLInputElement).value.trim();
    const bankNameholder = (document.getElementById('bank-nameholder-input') as HTMLInputElement).value.trim();
    (document.getElementById('btn-save-bank') as HTMLButtonElement).disabled = true;
    await saveSettings({
      bank_name: bankName,
      bank_account_number: bankAccount,
      bank_account_name: bankNameholder,
    }, 'Data rekening berhasil disimpan!');
    (document.getElementById('btn-save-bank') as HTMLButtonElement).disabled = false;
  });

  // Token Generation & Revocation
  const btnGenerateToken = document.getElementById('btn-generate-token') as HTMLButtonElement;
  const tokenLabelInput = document.getElementById('token-label-input') as HTMLInputElement;
  const tokenShowModal = document.getElementById('token-show-modal') as any;
  const rawTokenDisplay = document.getElementById('raw-token-display')!;

  btnGenerateToken?.addEventListener('click', async () => {
    const label = tokenLabelInput.value.trim();
    if (!label) {
      window.showToast?.('Label token tidak boleh kosong.', 'error');
      return;
    }
    btnGenerateToken.disabled = true;
    try {
      const apiClient = (window as any).apiClient || fetch;
      const res = await apiClient('/api/admin/tokens', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ label }),
      });
      if (res.ok) {
        const data = await res.json();
        rawTokenDisplay.textContent = data.token;
        tokenLabelInput.value = '';
        tokenShowModal?.showModal();
        tokenShowModal?.addEventListener('close', () => {
          window.location.reload();
        }, { once: true });
      } else {
        window.showToast?.('Gagal membuat token API.', 'error');
      }
    } catch {
      window.showToast?.('Terjadi kesalahan jaringan.', 'error');
    } finally {
      btnGenerateToken.disabled = false;
    }
  });

  document.querySelectorAll('.btn-revoke-token').forEach(btn => {
    btn.addEventListener('click', async (e) => {
      const target = e.currentTarget as HTMLButtonElement;
      const id = target.dataset.id!;
      if (!confirm('Apakah Anda yakin ingin me-revoke token ini? Asisten AI yang menggunakan token ini akan kehilangan akses.')) return;

      target.disabled = true;
      try {
        const apiClient = (window as any).apiClient || fetch;
        const res = await apiClient(`/api/admin/tokens/${id}`, { method: 'DELETE' });
        if (res.ok) {
          window.showToast?.('Token berhasil di-revoke!', 'success');
          window.location.reload();
        } else {
          window.showToast?.('Gagal me-revoke token.', 'error');
        }
      } catch {
        window.showToast?.('Terjadi kesalahan jaringan.', 'error');
      } finally {
        target.disabled = false;
      }
    });
  });
</script>
