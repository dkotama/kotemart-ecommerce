---
export const prerender = false;

import '../styles/global.css';
import { env } from 'cloudflare:workers';
import { getSettings } from '../lib/pricing';
// Standalone page — logged-in users are redirected to /catalog by middleware

let arrivalNotification = '';
try {
  const db = (env as any).DB;
  if (db) {
    arrivalNotification = (await getSettings(db)).arrival_notification;
  }
} catch (err) {
  console.error('Settings fetch error:', err);
}
---

<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Kotemart Jastip — Katalog Belanja Jepang</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" href="/favicon.ico" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700&family=JetBrains+Mono:wght@400;500;600;700&display=swap"
    rel="stylesheet"
  />
  <style>
    @keyframes marquee-scroll {
      from { transform: translateX(0); }
      to   { transform: translateX(-50%); }
    }
    .animate-marquee {
      animation: marquee-scroll 40s linear infinite;
      display: flex;
      width: max-content;
    }
    .marquee-track:hover .animate-marquee {
      animation-play-state: paused;
    }
  </style>
</head>
<body class="min-h-screen bg-[#F9F9F7] flex flex-col justify-center items-center p-4 text-[#1A1D23]">

  {arrivalNotification && (
    <div class="w-full max-w-[700px] mx-auto mb-6 bg-[#FDF3E7] border border-[#D4890B] rounded-[8px] px-4 py-3 flex items-center gap-3 text-[0.875rem]">
      <svg class="w-5 h-5 shrink-0 text-[#D4890B]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <span class="text-[#8B5E0A] font-medium">{arrivalNotification}</span>
    </div>
  )}

  <!-- Logo + Brand -->
  <div class="mb-8 text-center">
    <div class="w-[72px] h-[72px] mx-auto mb-5 rounded-[18px] flex items-center justify-center"
         style="background: linear-gradient(135deg, #0F726E 0%, #1A8F89 100%); box-shadow: 0 4px 16px rgba(15,114,110,0.25);">
      <span class="text-[2rem] font-bold text-white leading-none tracking-[-0.03em]">KM</span>
    </div>
    <h1 class="text-[2.5rem] font-bold leading-[1.15] tracking-[-0.03em] text-[#1A1D23]">
      Kotemart Jastip
    </h1>
    <p class="text-[0.6875rem] font-semibold leading-[1.3] tracking-[0.1em] uppercase text-[#1A8F89] mt-2">
      Katalog Belanja Jepang
    </p>
  </div>

  <!-- Marketplace Marquee -->
  <div class="w-full max-w-[700px] mb-10">
    <p class="text-[0.6875rem] font-semibold uppercase tracking-[0.1em] text-[#A5A9B2] text-center mb-3">
      Langsung dari marketplace Jepang
    </p>
    <div class="w-full overflow-hidden bg-[#FFFFFF] border border-[#E8E9ED] rounded-[10px] py-[18px] marquee-track relative"
         style="box-shadow: 0 1px 3px rgba(26,29,35,0.04);">
      <div class="absolute left-0 top-0 bottom-0 w-[48px] bg-gradient-to-r from-[#FFFFFF] to-transparent z-10 rounded-l-[10px] pointer-events-none"></div>
      <div class="absolute right-0 top-0 bottom-0 w-[48px] bg-gradient-to-l from-[#FFFFFF] to-transparent z-10 rounded-r-[10px] pointer-events-none"></div>
      <div class="animate-marquee flex items-center gap-[56px] px-[28px]">
        <!-- Amazon JP · #FF9900 -->
        <span style="color:#FF9900" class="text-[1.375rem] font-extrabold tracking-[-0.02em] whitespace-nowrap leading-none">amazon<span class="text-[0.625rem] align-super ml-0.5" style="color:#FF9900">JP</span></span>
        <!-- Yahoo! Japan · #FF0033 -->
        <span style="color:#FF0033" class="text-[1.125rem] font-black italic tracking-[-0.03em] whitespace-nowrap leading-none" title="Yahoo! Japan">Y!<span class="text-[0.75rem] font-bold not-italic ml-1">JAPAN</span></span>
        <!-- Rakuten · #BF0000 -->
        <span style="color:#BF0000" class="text-[1.25rem] font-black tracking-[-0.02em] whitespace-nowrap leading-none">Rakuten</span>
        <!-- Mercari · #FF3333 -->
        <span style="color:#FF3333" class="text-[1.25rem] font-extrabold tracking-[-0.02em] whitespace-nowrap leading-none">mercari</span>
        <!-- ZOZOTOWN · #1A1D23 -->
        <span style="color:#1A1D23" class="text-[1.125rem] font-black tracking-[0.04em] whitespace-nowrap leading-none">ZOZOTOWN</span>
        <!-- UNIQLO · #E60012 -->
        <span style="color:#E60012" class="text-[1.125rem] font-bold tracking-[-0.01em] whitespace-nowrap leading-none">UNIQLO</span>
        <!-- 駿河屋 · #4A4A4A -->
        <span style="color:#4A4A4A" class="text-[1.25rem] font-bold whitespace-nowrap leading-none">駿河屋</span>
        <!-- BicCamera · #E3001B -->
        <span style="color:#E3001B" class="text-[1.125rem] font-black tracking-[-0.02em] whitespace-nowrap leading-none">BicCamera</span>
        <!-- Yodobashi · #0066CC -->
        <span style="color:#0066CC" class="text-[1.125rem] font-extrabold tracking-[-0.01em] whitespace-nowrap leading-none">Yodobashi</span>
        <!-- Don Quijote · #FF6600 -->
        <span style="color:#FF6600" class="text-[1.125rem] font-black tracking-[-0.02em] whitespace-nowrap leading-none">Don Quijote</span>
        <!-- MUJI · #7F0000 -->
        <span style="color:#7F0000" class="text-[1.25rem] font-bold whitespace-nowrap leading-none">無印良品</span>
        <!-- Tsutaya · #F5A623 -->
        <span style="color:#F5A623" class="text-[1.125rem] font-extrabold whitespace-nowrap leading-none">TSUTAYA</span>

        <!-- Duplicate for seamless loop -->
        <span style="color:#FF9900" class="text-[1.375rem] font-extrabold tracking-[-0.02em] whitespace-nowrap leading-none">amazon<span class="text-[0.625rem] align-super ml-0.5" style="color:#FF9900">JP</span></span>
        <span style="color:#FF0033" class="text-[1.125rem] font-black italic tracking-[-0.03em] whitespace-nowrap leading-none">Y!<span class="text-[0.75rem] font-bold not-italic ml-1">JAPAN</span></span>
        <span style="color:#BF0000" class="text-[1.25rem] font-black tracking-[-0.02em] whitespace-nowrap leading-none">Rakuten</span>
        <span style="color:#FF3333" class="text-[1.25rem] font-extrabold tracking-[-0.02em] whitespace-nowrap leading-none">mercari</span>
        <span style="color:#1A1D23" class="text-[1.125rem] font-black tracking-[0.04em] whitespace-nowrap leading-none">ZOZOTOWN</span>
        <span style="color:#E60012" class="text-[1.125rem] font-bold tracking-[-0.01em] whitespace-nowrap leading-none">UNIQLO</span>
        <span style="color:#4A4A4A" class="text-[1.25rem] font-bold whitespace-nowrap leading-none">駿河屋</span>
        <span style="color:#E3001B" class="text-[1.125rem] font-black tracking-[-0.02em] whitespace-nowrap leading-none">BicCamera</span>
        <span style="color:#0066CC" class="text-[1.125rem] font-extrabold tracking-[-0.01em] whitespace-nowrap leading-none">Yodobashi</span>
        <span style="color:#FF6600" class="text-[1.125rem] font-black tracking-[-0.02em] whitespace-nowrap leading-none">Don Quijote</span>
        <span style="color:#7F0000" class="text-[1.25rem] font-bold whitespace-nowrap leading-none">無印良品</span>
        <span style="color:#F5A623" class="text-[1.125rem] font-extrabold whitespace-nowrap leading-none">TSUTAYA</span>
      </div>
    </div>
  </div>

  <!-- Login CTA -->
  <div class="w-full max-w-[400px] text-center mb-8">
    <p class="text-[0.9375rem] leading-[1.6] text-[#5B606D] mb-6">
      Platform jasa titip tertutup. Produk eksklusif Jepang — elektronik, figure, skincare, suplemen, dan lainnya.
    </p>

    <a
      href="/api/auth/login"
      class="inline-flex items-center justify-center gap-3 h-[48px] px-10 rounded-[8px] text-[0.6875rem] font-semibold uppercase tracking-[0.1em] text-white no-underline transition-all duration-150"
      style="background: linear-gradient(135deg, #0F726E 0%, #1A8F89 100%); box-shadow: 0 2px 8px rgba(15,114,110,0.18);"
      onmouseover="this.style.boxShadow='0 4px 16px rgba(15,114,110,0.28)'; this.style.transform='translateY(-1px)'"
      onmouseout="this.style.boxShadow='0 2px 8px rgba(15,114,110,0.18)'; this.style.transform='none'"
    >
      <svg class="w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none">
        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="currentColor"/>
        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.16v2.84C3.99 20.53 7.7 23 12 23z" fill="currentColor"/>
        <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.16C1.43 8.55 1 10.22 1 12s.43 3.45 1.16 4.93l3.68-2.84z" fill="currentColor"/>
        <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.16 7.07l3.68 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="currentColor"/>
      </svg>
      Masuk dengan Google
    </a>
  </div>


  <!-- Footer -->
  <p class="text-[0.8125rem] text-[#5B606D]">
    <a href="/privacy" class="text-[#1A8F89] no-underline hover:underline">Kebijakan Privasi</a>
    <span class="mx-2 text-[#D8DBDF]">|</span>
    <a href="/terms" class="text-[#1A8F89] no-underline hover:underline">Syarat & Ketentuan</a>
  </p>
  <p class="mt-4 text-[0.75rem] text-[#A5A9B2]">&copy; 2026 Kotemart Jastip</p>

</body>
</html>
