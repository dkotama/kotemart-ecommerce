---
export const prerender = false;

import '../styles/global.css';

// Login page is standalone (no Layout.astro) to avoid navbar
---

<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Masuk — Kotemart</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" href="/favicon.ico" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700&family=JetBrains+Mono:wght@400;500;600;700&display=swap"
    rel="stylesheet"
  />
</head>
<body class="min-h-screen bg-[#F9F9F7] flex flex-col justify-center items-center p-4 text-[#1A1D23]">

  <!-- Branding Header -->
  <div class="mb-10 text-center">
    <h1 class="text-[2.5rem] font-bold leading-[1.15] tracking-[-0.03em] text-[#1A1D23]">
      Kotemart
    </h1>
    <p class="text-[0.6875rem] font-semibold leading-[1.3] tracking-[0.1em] uppercase text-[#1A8F89] mt-2">
      Jastip Catalog
    </p>
  </div>

  <!-- Login Card -->
  <div
    class="w-full max-w-[400px] bg-[#FFFFFF] rounded-[10px] p-8"
    style="box-shadow: 0 1px 3px rgba(26, 29, 35, 0.06), 0 1px 2px rgba(26, 29, 35, 0.04);"
  >
    <div class="text-center mb-8">
      <h2 class="text-[1.75rem] font-semibold leading-[1.25] tracking-[-0.02em] text-[#1A1D23] mb-3">
        Masuk
      </h2>
      <p class="text-[0.9375rem] leading-[1.55] text-[#5B606D]">
        Login aman menggunakan akun Google. Tidak perlu mendaftar manual.
      </p>
    </div>

    <!-- Google Login Button -->
    <a
      href="/api/auth/login"
      class="w-full h-[44px] flex items-center justify-center gap-3 bg-[#0F726E] hover:bg-[#0A5D59] text-[#FFFFFF] rounded-[6px] px-[12px] transition-all duration-150 ease-out focus:outline-none focus:ring-2 focus:ring-[#1A8F89] focus:ring-offset-2 focus:ring-offset-[#FFFFFF] no-underline"
    >
      <!-- Pure White Google SVG -->
      <svg class="w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none">
        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="currentColor"/>
        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.16v2.84C3.99 20.53 7.7 23 12 23z" fill="currentColor"/>
        <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.16C1.43 8.55 1 10.22 1 12s.43 3.45 1.16 4.93l3.68-2.84z" fill="currentColor"/>
        <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.16 7.07l3.68 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="currentColor"/>
      </svg>
      <span class="text-[0.6875rem] font-semibold leading-[1.3] tracking-[0.1em] uppercase">
        Login dengan Google
      </span>
    </a>

    <!-- Divider & Privacy Context -->
    <div class="mt-8 flex items-center justify-center">
      <div class="h-[1px] w-full bg-[#E8E9ED]"></div>
      <span class="px-3 text-[#5B606D] text-[0.6875rem] font-semibold tracking-[0.1em] uppercase bg-[#FFFFFF] whitespace-nowrap">
        Private
      </span>
      <div class="h-[1px] w-full bg-[#E8E9ED]"></div>
    </div>

    <p class="mt-5 text-[0.8125rem] leading-[1.5] text-[#5B606D] text-center">
      Katalog jastip ini bersifat tertutup. Hanya pembeli yang telah dikonfirmasi oleh admin yang dapat melakukan pemesanan.
    </p>
  </div>

  {import.meta.env.DEV && (
  /* LOCAL DEV SECTION: Mock login buttons */
  <div class="mt-8 w-full max-w-[400px]">
    <div
      class="bg-[#F1F2F5] border border-[#E8E9ED] rounded-[10px] p-6"
      style="border-style: dashed;"
    >
      <div class="flex items-center gap-2 mb-4">
        <svg class="w-4 h-4 text-[#D4890B]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
        </svg>
        <span class="text-[0.6875rem] font-semibold uppercase tracking-[0.1em] text-[#D4890B]">
          Dev Tools Only
        </span>
      </div>
      <p class="text-[0.8125rem] text-[#5B606D] mb-4 leading-[1.5]">
        Bypass Google OAuth untuk pengembangan lokal. Tidak tersedia di production.
      </p>
      <div class="flex gap-3">
        <a
          href="/api/auth/mock-login?role=buyer"
          class="flex-1 h-[44px] flex items-center justify-center bg-[#FFFFFF] border border-[#E8E9ED] hover:bg-[#F9F9F7] text-[#1A1D23] rounded-[6px] text-[0.6875rem] font-semibold uppercase tracking-[0.1em] transition-all no-underline"
        >
          Login sebagai Buyer
        </a>
        <a
          href="/api/auth/mock-login?role=admin"
          class="flex-1 h-[44px] flex items-center justify-center bg-[#1A1D23] hover:bg-[#2a2e38] text-[#FFFFFF] rounded-[6px] text-[0.6875rem] font-semibold uppercase tracking-[0.1em] transition-all no-underline"
        >
          Login sebagai Admin
        </a>
      </div>
    </div>
  </div>
  )}

</body>
</html>
