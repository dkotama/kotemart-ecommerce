---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import type { Order } from '../lib/types';
import { env } from 'cloudflare:workers';
import { getSettings } from '../lib/pricing';

const user = Astro.locals.user;

if (!user) {
  return Astro.redirect('/login?redirect=/my-orders');
}

// Extended order type with user info
type OrderRow = Order & {
  buyer_name?: string;
  buyer_email?: string;
};

let orders: OrderRow[] = [];

try {
  const db = (env as any).DB;
  if (db) {
    const result = await db.prepare(
      `SELECT id, user_id, product_id, type, name, description, reference_url, qty,
              status, price_jpy, jpy_rate_snapshot, fee_pct_snapshot,
              price_idr_estimate, price_idr_final, manual_idr_override,
              down_payment_idr, paid_amount_idr,
              notes, cancellation_reason, cancelled_at, settled_at, created_at,
              (SELECT images FROM products WHERE products.id = orders.product_id LIMIT 1) as product_images
       FROM orders
       WHERE user_id = ?
       ORDER BY created_at DESC`
    ).bind(user.id).all<OrderRow & { product_images: string | null }>();

    if (result?.results) {
      orders = result.results.map(o => ({
        ...o,
        _images: (() => {
          try { return o.product_images ? JSON.parse(o.product_images) : []; }
          catch { return []; }
        })(),
      })) as OrderRow[];
    }
  }
} catch (err) {
  console.error('My orders fetch error:', err);
}

let settings = {
  arrival_notification: '',
  bank_name: '',
  bank_account_number: '',
  bank_account_name: '',
};
try {
  const db = (env as any).DB;
  if (db) {
    settings = await getSettings(db);
  }
} catch (err) {
  console.error('Settings fetch error:', err);
}
const arrivalNotification = settings.arrival_notification;
const bankName = settings.bank_name;
const bankAccountNumber = settings.bank_account_number;
const bankAccountName = settings.bank_account_name;

const STATUS_STEPS = ['Draft', 'Pending', 'Bought'] as const;
const STATUS_INDEX: Record<string, number> = { Draft: 0, Pending: 1, Bought: 2 };

const completedPurchases = orders
  .filter(o => o.status === 'Bought' && o.price_idr_final != null)
  .reduce((sum, o) => sum + ((o.price_idr_final ?? 0) * o.qty), 0);

const outstandingDeposits = orders
  .filter(o => o.status === 'Pending'
    && o.down_payment_idr != null
    && (o.paid_amount_idr ?? 0) < (o.down_payment_idr ?? 0))
  .reduce((sum, o) => sum + Math.max((o.down_payment_idr ?? 0) - (o.paid_amount_idr ?? 0), 0), 0);

const totalDue = completedPurchases + outstandingDeposits;
const hasBank = !!(bankAccountNumber);
---

<Layout title="Pesanan Saya" user={user}>
  <main class="max-w-[800px] mx-auto px-4 md:px-6 pt-[32px] md:pt-[48px] pb-24">

    <!-- Page Header -->
    <div class="mb-[32px] md:mb-[48px]">
      <h1 class="text-[2.5rem] font-bold leading-[1.15] tracking-[-0.03em] text-[#1A1D23]">
        Pesanan Saya
      </h1>
      <p class="text-[1.125rem] leading-[1.6] text-[#5B606D] mt-2">
        Pantau status pesanan jastip Anda. Harga final akan muncul ketika barang berhasil dibeli (Bought).
      </p>
    </div>

    {arrivalNotification && (
      <div class="mb-[24px] bg-[#FDF3E7] border border-[#D4890B] rounded-[8px] px-4 py-3 flex items-center gap-3 text-[0.875rem]">
        <svg class="w-5 h-5 shrink-0 text-[#D4890B]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <span class="text-[#8B5E0A] font-medium">{arrivalNotification}</span>
      </div>
    )}

    <!-- Payment Summary Card -->
    {totalDue > 0 && (
      <div class="mb-[32px] bg-[#FFFFFF] border border-[#E8E9ED] rounded-[10px] p-[24px] shadow-[0_1px_3px_rgba(26,29,35,0.06),0_1px_2px_rgba(26,29,35,0.04)] flex flex-col md:flex-row md:items-start justify-between gap-[24px]">
        <div class="flex-1">
          <h2 class="text-[0.9375rem] font-semibold leading-[1.55] text-[#5B606D] mb-1">Total Tagihan Sekarang</h2>
          <span class="text-[2rem] font-bold leading-[1.2] tracking-[-0.02em] text-[#1A1D23]">
            Rp {totalDue.toLocaleString('id-ID')}
          </span>
          <div class="mt-3 flex flex-col gap-1.5 max-w-[360px]">
            {completedPurchases > 0 && (
              <div class="flex items-center justify-between gap-3 text-[0.8125rem]">
                <span class="text-[#5B606D]">Items Bought <span class="text-[#5B606D]/70">(Siap Bayar Final)</span></span>
                <span class="font-semibold text-[#1A1D23]">Rp {completedPurchases.toLocaleString('id-ID')}</span>
              </div>
            )}
            {outstandingDeposits > 0 && (
              <div class="flex items-center justify-between gap-3 text-[0.8125rem]">
                <span class="text-[#5B606D]">Pending Deposits <span class="text-[#8B5E0A]">(DP Belum Dibayar)</span></span>
                <span class="font-semibold text-[#8B5E0A]">Rp {outstandingDeposits.toLocaleString('id-ID')}</span>
              </div>
            )}
          </div>
        </div>

        <div class="bg-[#F9F9F7] border border-[#E8E9ED] rounded-[6px] p-[16px] w-full md:w-[320px] shrink-0">
          <h3 class="text-[0.6875rem] font-semibold uppercase tracking-[0.1em] text-[#5B606D] mb-4">Transfer ke Bank Berikut</h3>
          <div class="flex justify-between items-center mb-3">
            <span class="text-[0.8125rem] text-[#5B606D]">{bankName || 'Bank'}</span>
            <span class="font-mono text-[1rem] font-bold text-[#1A1D23]">{bankAccountNumber || '—'}</span>
          </div>
          {bankAccountName && (
            <div class="flex justify-between items-center">
              <span class="text-[0.8125rem] text-[#5B606D]">Atas Nama</span>
              <span class="text-[0.8125rem] font-semibold text-[#1A1D23]">{bankAccountName}</span>
            </div>
          )}
          <div class="mt-4 pt-4 border-t border-[#E8E9ED]">
            <button
              id="copy-rekening-btn"
              class="w-full text-center text-[0.6875rem] font-semibold uppercase tracking-[0.1em] text-[#1A8F89] hover:text-[#0F726E] transition-colors flex items-center justify-center gap-2"
            >
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
              </svg>
              Salin No. Rekening
            </button>
          </div>
        </div>
      </div>
    )}

    <!-- Orders List -->
    {orders.length === 0 ? (
      <div class="py-[64px] text-center border border-[#E8E9ED] border-dashed rounded-[10px] bg-[#FFFFFF]">
        <svg class="w-12 h-12 text-[#5B606D] opacity-30 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
        </svg>
        <p class="text-[1.125rem] text-[#5B606D]">Belum ada pesanan.</p>
        <p class="text-[0.8125rem] text-[#5B606D] opacity-70 mt-2">Mulai dari katalog atau buat Custom Order.</p>
        <a href="/catalog" class="mt-4 inline-flex h-[44px] px-[16px] bg-[#0F726E] text-[#FFFFFF] rounded-[6px] text-[0.6875rem] font-semibold uppercase tracking-[0.1em] items-center gap-2 no-underline hover:bg-[#0A5D59] transition-colors">
          Lihat Katalog
        </a>
      </div>
    ) : (
      <div data-testid="orders-list" class="flex flex-col gap-[12px]">
        {orders.map((order: any) => {
          const currentStepIdx = STATUS_INDEX[order.status] ?? 0;
          const isCancelled = order.status === 'Cancelled';
          const isBought = order.status === 'Bought';
          const imgSrc = order._images?.[0] ?? null;

          return (
            <div
              data-testid="order-row"
              data-status={order.status}
              class={`bg-[#FFFFFF] border rounded-[10px] p-[16px] transition-shadow hover:shadow-[0_2px_8px_rgba(26,29,35,0.06)] ${isCancelled ? 'border-[#F5C2C0] bg-red-50/30' : 'border-[#E8E9ED]'}`}
            >
              <div class="flex flex-col md:flex-row items-start md:items-center gap-[16px]">

                <!-- Left: Image & Info -->
                <div class="flex items-start gap-[12px] w-full md:flex-1">
                  <!-- Thumbnail -->
                  <div class={`w-[56px] h-[56px] md:w-[64px] md:h-[64px] shrink-0 bg-[#F1F2F5] rounded-[6px] border border-[#E8E9ED] overflow-hidden flex items-center justify-center ${isCancelled ? 'opacity-50 grayscale' : ''}`}>
                    {imgSrc ? (
                      <img src={imgSrc} alt={order.name} class="w-full h-full object-cover" />
                    ) : (
                      <svg class="w-6 h-6 text-[#5B606D] opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                      </svg>
                    )}
                  </div>

                  <!-- Order Info -->
                  <div class="flex-grow min-w-0 pt-0.5">
                    <div class="flex items-center gap-2 mb-1 flex-wrap">
                      <span class={`font-mono text-[0.75rem] font-semibold ${isCancelled ? 'text-[#A6312A]' : 'text-[#1A1D23]'}`}>
                        {order.id}
                      </span>
                      <span class={`px-[6px] py-[2px] rounded-[3px] text-[0.625rem] font-semibold uppercase tracking-[0.1em] ${order.type === 'custom' ? 'bg-[#E8E9ED] text-[#1A1D23]' : 'bg-[#D5EDEB] text-[#0F726E]'}`}>
                        {order.type === 'custom' ? 'Custom' : 'Catalog'}
                      </span>
                      <span
                        data-testid="status-badge"
                        class={`px-[6px] py-[2px] rounded-[3px] text-[0.625rem] font-semibold uppercase tracking-[0.1em] badge-${order.status.toLowerCase()}`}
                      >
                        {order.status}
                      </span>
                      <span class="text-[0.6875rem] text-[#5B606D] hidden sm:block">
                        {order.created_at ? new Date(order.created_at).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' }) : ''}
                      </span>
                    </div>
                    <h3 class={`text-[0.9375rem] font-semibold leading-[1.3] text-[#1A1D23] line-clamp-1 mb-1 ${isCancelled ? 'line-through opacity-70' : ''}`}>
                      {order.name}
                    </h3>
                    <p class="text-[0.8125rem] text-[#5B606D]">Qty: {order.qty}</p>
                    {isCancelled && order.cancellation_reason && (
                      <p class="text-[0.75rem] text-[#A6312A] mt-1">Alasan: {order.cancellation_reason}</p>
                    )}
                  </div>
                </div>

                <!-- Middle: Status Stepper -->
                <div class="w-full md:w-[200px] lg:w-[240px] shrink-0 pt-3 md:pt-0 border-t md:border-t-0 border-[#E8E9ED]">
                  {isCancelled ? (
                    <div class="flex items-center gap-1.5 text-[#D1453B]">
                      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
                      </svg>
                      <span class="text-[0.75rem] font-semibold uppercase tracking-[0.05em]">Dibatalkan</span>
                    </div>
                  ) : (
                    <div class="relative w-full">
                      <div class="flex items-center justify-between w-full relative z-10">
                        {STATUS_STEPS.map((step, idx) => {
                          const isActive = currentStepIdx >= idx;
                          return (
                            <div class="flex flex-col items-center gap-1.5 w-1/3">
                              <div class={`w-[10px] h-[10px] rounded-full border-[1.5px] z-10 ${isActive ? 'border-[#1A8F89] bg-[#1A8F89]' : 'border-[#E8E9ED] bg-[#FFFFFF]'}`} />
                              <span class={`text-[0.625rem] font-semibold uppercase tracking-[0.05em] ${isActive ? 'text-[#1A1D23]' : 'text-[#5B606D] opacity-60'}`}>
                                {step}
                              </span>
                            </div>
                          );
                        })}
                      </div>
                      {/* Progress Line */}
                      <div class="absolute top-[4.5px] left-[12.5%] right-[12.5%] h-[1.5px] bg-[#E8E9ED] z-0">
                        <div
                          class="h-full bg-[#1A8F89] transition-all"
                          style={`width: ${(currentStepIdx / (STATUS_STEPS.length - 1)) * 100}%`}
                        />
                      </div>
                    </div>
                  )}
                </div>

                <!-- Right: Prices -->
                <div class="w-full md:w-[130px] shrink-0 flex flex-row md:flex-col items-end justify-between md:justify-center border-t md:border-t-0 border-[#E8E9ED] pt-3 md:pt-0">
                  <span class={`font-mono text-[0.75rem] text-[#5B606D] md:mb-1 ${isCancelled ? 'opacity-60' : ''}`}>
                    {order.price_jpy ? `¥ ${(order.price_jpy * order.qty).toLocaleString('ja-JP')}` : '¥ —'}
                  </span>
                  <div class="flex flex-col items-end">
                    {isCancelled ? (
                      <>
                        <span class="text-[0.5625rem] font-semibold uppercase tracking-[0.1em] text-[#5B606D] mb-0.5">Dibatalkan</span>
                        <span class="text-[1rem] font-bold text-[#5B606D] line-through">
                          {order.price_idr_estimate ? `Rp ${(order.price_idr_estimate * order.qty).toLocaleString('id-ID')}` : '—'}
                        </span>
                      </>
                    ) : isBought ? (
                      <>
                        <span class="text-[0.5625rem] font-semibold uppercase tracking-[0.1em] text-[#1E6B3F] mb-0.5">Final</span>
                        <span data-testid="price-final" class="text-[1.125rem] font-bold text-[#1A1D23]">
                          Rp {((order.price_idr_final ?? 0) * order.qty).toLocaleString('id-ID')}
                        </span>
                      </>
                    ) : (
                      <>
                        <span class="text-[0.5625rem] font-semibold uppercase tracking-[0.1em] text-[#8B5E0A] mb-0.5">Est</span>
                        <div class="flex flex-col items-end gap-1">
                          <span class="text-[1.125rem] font-bold text-[#1A8F89]">
                            {(() => { const v = (order as any).manual_idr_override ?? order.price_idr_estimate; return v ? `Rp ${(v * order.qty).toLocaleString('id-ID')}` : '🔒 TBA'; })()}
                          </span>
                          {order.status === 'Pending' && order.down_payment_idr != null && ((order.paid_amount_idr ?? 0) < order.down_payment_idr) && (
                            <span class="px-1.5 py-0.5 bg-[#FDF3E7] border border-[#F0D5B1] text-[#8B5E0A] rounded-[3px] text-[0.625rem] font-bold whitespace-nowrap">
                              DP Rp {((order.down_payment_idr - (order.paid_amount_idr ?? 0))).toLocaleString('id-ID')} Unpaid
                            </span>
                          )}
                        </div>
                      </>
                    )}
                  </div>
                </div>

              </div>

              {order.down_payment_idr != null && (
                <div class="border-t border-[#E8E9ED] mt-3 pt-3 flex items-center justify-between gap-2 text-[0.8125rem]">
                  <div class="flex items-center gap-2 flex-wrap">
                    <span class="text-[#5B606D]">Uang Muka (DP): <span class="font-semibold text-[#1A1D23]">Rp {(order.down_payment_idr as number).toLocaleString('id-ID')}</span></span>
                    <span class={`px-[6px] py-[1.5px] rounded text-[0.625rem] font-bold uppercase tracking-[0.08em] ${((order.paid_amount_idr ?? 0) as number) >= (order.down_payment_idr as number) ? 'bg-[#D9EDE2] text-[#1E6B3F]' : 'bg-[#FDF3E7] text-[#8B5E0A] border border-[#F0D5B1]'}`}>
                      {((order.paid_amount_idr ?? 0) as number) >= (order.down_payment_idr as number) ? 'Terbayar' : 'Belum Lunas'}
                    </span>
                  </div>
                  {((order.paid_amount_idr ?? 0) as number) < (order.down_payment_idr as number) && (
                    <span class="text-[#8B5E0A] font-semibold">
                      Sisa DP: Rp {Math.max((order.down_payment_idr as number) - (order.paid_amount_idr ?? 0 as number), 0).toLocaleString('id-ID')}
                    </span>
                  )}
                </div>
              )}
            </div>
          );
        })}
      </div>
    )}

  </main>
</Layout>

<script define:vars={{ bankAccountNumber }}>
  document.getElementById('copy-rekening-btn')?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(bankAccountNumber);
      window.showToast?.('No. Rekening berhasil disalin!', 'success');
    } catch {
      window.showToast?.('Gagal menyalin nomor rekening.', 'error');
    }
  });
</script>
